# ─── Application ───────────────────────────────────────────────────────────
APP_NAME=RAG Healthcare Assistant
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change-this-to-a-256-bit-random-key-in-production

# ─── PostgreSQL ─────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=healthcare_user
POSTGRES_PASSWORD=healthcare_pass
POSTGRES_DB=healthcare_rag

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
CACHE_TTL_SECONDS=3600

# ─── LLM Providers ──────────────────────────────────────────────────────────
# Set at least one of these:
OPENAI_API_KEY=sk-your-openai-api-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# Which provider to use: openai | anthropic
LLM_PROVIDER=openai
EMBEDDING_PROVIDER=openai

OPENAI_LLM_MODEL=gpt-4-turbo-preview
OPENAI_EMBEDDING_MODEL=text-embedding-ada-002
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ─── RAG Settings ───────────────────────────────────────────────────────────
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
MAX_RETRIEVAL_DOCS=5
SIMILARITY_THRESHOLD=0.65
MAX_DOCUMENT_SIZE_MB=50

# ─── Security ───────────────────────────────────────────────────────────────
ENCRYPTION_KEY=change-this-to-32-byte-encryption-key
ACCESS_TOKEN_EXPIRE_MINUTES=30
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ─── Admin User (auto-created on first startup) ───────────────────────────
ADMIN_EMAIL=admin@healthcare.local
ADMIN_PASSWORD=Admin@12345!

# ─── Rate Limiting ──────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# ─── Observability ──────────────────────────────────────────────────────────
JAEGER_HOST=localhost
JAEGER_PORT=6831
ENABLE_METRICS=true

# ─── AWS (optional, for S3 document storage) ────────────────────────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# S3_BUCKET=healthcare-rag-documents
